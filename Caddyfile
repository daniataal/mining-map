# HTTP only (host :8080 → container :80). No TLS / auto_https globals needed.
:80 {
	encode gzip zstd

	# Go oil-live-intel (canonical /api/oil-live/*)
	handle /api/oil-live/* {
		reverse_proxy oil-live-intel:8095 {
			transport http {
				read_timeout 0
				write_timeout 0
			}
		}
	}

	# Python-only license annotations (must precede /api/licenses* → Go)
	handle /api/licenses/annotations {
		reverse_proxy backend:8000
	}
	handle /api/licenses/*/annotations {
		reverse_proxy backend:8000
	}

	handle_path /api/licenses* {
		rewrite * /api/oil-live/licenses{path}
		reverse_proxy oil-live-intel:8095 {
			transport http {
				read_timeout 0
				write_timeout 0
			}
		}
	}
	handle_path /licenses* {
		rewrite * /api/oil-live/licenses{path}
		reverse_proxy oil-live-intel:8095 {
			transport http {
				read_timeout 0
				write_timeout 0
			}
		}
	}

	handle_path /entities* {
		rewrite * /entities{path}
		reverse_proxy oil-live-intel:8095 {
			transport http {
				read_timeout 0
				write_timeout 0
			}
		}
	}

	# Frontend-friendly paths → oil-live-intel (uri replace avoids duplicating {path})
	handle /api/map/country-borders* {
		uri replace /api/map/country-borders /api/oil-live/map/country-borders
		reverse_proxy oil-live-intel:8095 {
			transport http {
				read_timeout 0
				write_timeout 0
			}
		}
	}
	# OSM petroleum GeoJSON catalog + layers (Postgres snapshot; Python until Go parity is default)
	handle /api/petroleum/osm-layers* {
		reverse_proxy backend:8000 {
			transport http {
				read_timeout 0
				write_timeout 0
			}
		}
	}
	handle /api/petroleum/osm-tiles* {
		uri replace /api/petroleum/osm-tiles /api/oil-live/map/petroleum-osm/tiles
		reverse_proxy oil-live-intel:8095 {
			transport http {
				read_timeout 0
				write_timeout 0
			}
		}
	}
	handle /api/maritime/stats* {
		uri replace /api/maritime/stats /api/oil-live/maritime/stats
		reverse_proxy oil-live-intel:8095 {
			transport http {
				read_timeout 0
				write_timeout 0
			}
		}
	}
	handle /api/maritime/context* {
		uri replace /api/maritime/context /api/oil-live/maritime/context
		reverse_proxy oil-live-intel:8095 {
			transport http {
				read_timeout 0
				write_timeout 0
			}
		}
	}
	handle /api/maritime/vessels* {
		uri replace /api/maritime/vessels /api/oil-live/vessels/live
		reverse_proxy oil-live-intel:8095 {
			transport http {
				read_timeout 0
				write_timeout 0
			}
		}
	}

	@backend {
		path /auth/* /activity/* /files/* /docs /openapi.json /api/*
	}
	reverse_proxy @backend backend:8000

	reverse_proxy * frontend:5173
}
