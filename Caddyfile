# HTTP only (host :8080 → container :80). No TLS / auto_https globals needed.
:80 {
	encode gzip zstd

	# Mutually exclusive routing — naked reverse_proxy at site root caused 400/404 for some API paths.
	route {
		# Go oil-live-intel (canonical /api/oil-live/*)
		handle /api/oil-live/* {
			reverse_proxy oil-live-intel:8095 {
				transport http {
					read_timeout 0
					write_timeout 0
				}
			}
		}

		# Python-only license annotations (must precede /api/licenses* → Go)
		handle /api/licenses/annotations {
			reverse_proxy backend:8000
		}
		handle /api/licenses/*/annotations {
			reverse_proxy backend:8000
		}

		handle_path /api/licenses* {
			rewrite * /api/oil-live/licenses{path}
			reverse_proxy oil-live-intel:8095 {
				transport http {
					read_timeout 0
					write_timeout 0
				}
			}
		}
		handle_path /licenses* {
			rewrite * /api/oil-live/licenses{path}
			reverse_proxy oil-live-intel:8095 {
				transport http {
					read_timeout 0
					write_timeout 0
				}
			}
		}

		handle_path /entities* {
			rewrite * /entities{path}
			reverse_proxy oil-live-intel:8095 {
				transport http {
					read_timeout 0
					write_timeout 0
				}
			}
		}

		# Frontend-friendly paths → oil-live-intel (uri replace avoids duplicating {path})
		handle /api/map/country-borders* {
			uri replace /api/map/country-borders /api/oil-live/map/country-borders
			reverse_proxy oil-live-intel:8095 {
				transport http {
					read_timeout 0
					write_timeout 0
				}
			}
		}

		# OSM petroleum GeoJSON catalog + layers (Go parity; Python fallback on :8000 direct)
		@petroleum_osm_layers {
			path /api/petroleum/osm-layers /api/petroleum/osm-layers/*
		}
		handle @petroleum_osm_layers {
			uri replace /api/petroleum/osm-layers /api/oil-live/map/petroleum-osm/layers
			reverse_proxy oil-live-intel:8095 {
				transport http {
					read_timeout 0
					write_timeout 0
				}
			}
		}

		handle /api/petroleum/osm-tiles* {
			uri replace /api/petroleum/osm-tiles /api/oil-live/map/petroleum-osm/tiles
			reverse_proxy oil-live-intel:8095 {
				transport http {
					read_timeout 0
					write_timeout 0
				}
			}
		}

		handle /api/petroleum/osm-features* {
			uri replace /api/petroleum/osm-features /api/oil-live/map/petroleum-osm/features
			reverse_proxy oil-live-intel:8095 {
				transport http {
					read_timeout 0
					write_timeout 0
				}
			}
		}
		handle /api/maritime/stats* {
			uri replace /api/maritime/stats /api/oil-live/maritime/stats
			reverse_proxy oil-live-intel:8095 {
				transport http {
					read_timeout 0
					write_timeout 0
				}
			}
		}
		handle /api/maritime/context* {
			uri replace /api/maritime/context /api/oil-live/maritime/context
			reverse_proxy oil-live-intel:8095 {
				transport http {
					read_timeout 0
					write_timeout 0
				}
			}
		}
		handle /api/maritime/vessels* {
			uri replace /api/maritime/vessels /api/oil-live/vessels/live
			reverse_proxy oil-live-intel:8095 {
				transport http {
					read_timeout 0
					write_timeout 0
				}
			}
		}

		@backend {
			path /auth/* /activity/* /files/* /docs /openapi.json /api/*
		}
		handle @backend {
			reverse_proxy backend:8000
		}

		# CDN-origin cache headers for Vite static assets (see Caddyfile.edge)
		@static_assets {
			path /assets/*
			path *.js *.css *.woff *.woff2 *.png *.jpg *.jpeg *.gif *.ico *.svg *.webp
		}
		handle @static_assets {
			header Cache-Control "public, max-age=31536000, immutable"
			reverse_proxy frontend:5173
		}

		@spa_shell {
			path / /index.html
		}
		handle @spa_shell {
			header Cache-Control "no-cache, must-revalidate"
			reverse_proxy frontend:5173
		}

		handle {
			reverse_proxy frontend:5173
		}
	}
}
