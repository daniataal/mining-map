# Copy to secrets.properties (gitignored). No trailing slash required.
#
# MERIDIAN_API_HOST — FastAPI backend (same as mining-viz VITE_API_BASE / default :8000).
#   Native mode uses this for REST. Emulator default if unset: http://10.0.2.2:8000
#
# MERIDIAN_WEB_HOST — mining-viz (Vite or deployed static). Only for optional legacy WebView.
#   Not required for native-first builds. Emulator default if unset: http://10.0.2.2:5173

MERIDIAN_API_HOST=http://10.0.2.2:8000
MERIDIAN_WEB_HOST=http://10.0.2.2:5173
