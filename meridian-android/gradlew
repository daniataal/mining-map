#!/bin/sh
#
# Meridian Trade OS — Gradle Wrapper Script
# The gradle-wrapper.jar is NOT committed. Generate it once with:
#   gradle wrapper --gradle-version=8.7 --distribution-type=bin
# (CI generates it automatically via the workflow bootstrap step.)
#

set -e

APP_HOME="$(cd "$(dirname "$0")" && pwd -P)"
WRAPPER_JAR="$APP_HOME/gradle/wrapper/gradle-wrapper.jar"

if [ ! -f "$WRAPPER_JAR" ]; then
    echo >&2 ""
    echo >&2 "ERROR: Gradle wrapper JAR not found."
    echo >&2 "  Run the following once in this directory:"
    echo >&2 "    gradle wrapper --gradle-version=8.7 --distribution-type=bin"
    echo >&2 ""
    exit 1
fi

if [ -n "$JAVA_HOME" ]; then
    JAVACMD="$JAVA_HOME/bin/java"
else
    JAVACMD="java"
fi

exec "$JAVACMD" \
    ${JAVA_OPTS:-} \
    ${GRADLE_OPTS:-} \
    -classpath "$WRAPPER_JAR" \
    org.gradle.wrapper.GradleWrapperMain \
    "$@"
