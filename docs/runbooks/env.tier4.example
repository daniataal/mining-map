# Tier-4 VM env template — placeholders only; copy into backend.env / shell export as needed.
# Do NOT commit real secrets. See docs/runbooks/VM_TIER4_OPS.md

# --- Compose / deploy ---
VERSION_TAG=v<run>
MINING_MAP_ROOT=/opt/mining-map
# Full scale stack (Tier 1 + 2 + 3 + 4):
# MINING_MAP_COMPOSE_FILES="docker-compose.prod.yml docker-compose.prod.app.yml docker-compose.prod.scale.yml"

# --- Tier 3 scale (docker-compose.prod.scale.yml) ---
# Defaults route through PgBouncer; override to bypass pooler:
SCALE_DB_HOST=pgbouncer
SCALE_DB_PORT=5432
SCALE_DATABASE_URL=postgresql://postgres:password@pgbouncer:5432/mining_db?sslmode=disable
UVICORN_WORKERS=3
OIL_INTEL_DB_MAX_CONNS=8
RATE_LIMIT_RPM=60
RATE_LIMIT_ROUTE_RPM=120

# --- PgBouncer (Tier 4 — on by default in scale overlay) ---
PGBOUNCER_MAX_CLIENT_CONN=200
PGBOUNCER_DEFAULT_POOL_SIZE=25
PGBOUNCER_RESERVE_POOL_SIZE=5

# --- Redis cache (Tier 2) ---
REDIS_URL=redis://redis:6379/1
RATE_LIMIT_ENABLED=1

# --- Scheduled ingest (cron scripts) ---
ADMIN_TOKEN=<admin-token-for-graph-sync-post>
VM_GRAPH_SYNC_URL=http://127.0.0.1:8080/api/admin/oil-live/graph-sync
VM_INGEST_GRAPH_TIMEOUT=600
VM_INGEST_WAIT_SECONDS=7200
VM_INGEST_LICENSE_WAIT_SECONDS=3600

# --- Health probe ---
MINING_MAP_CADDY_PORT=8080
VM_HEALTH_MODE=caddy-only

# --- Ingest VM (second host — docker-compose.prod.ingest.yml) ---
# DB_HOST=<app-vm-private-ip>
# DATABASE_URL=postgresql://postgres:<password>@<app-vm-ip>:5432/mining_db?sslmode=disable
# OIL_INTEL_API_URL=http://<app-vm-ip>:8095

# --- External API keys (required when ingest workers run) ---
# COMTRADE_API_KEY=
# EIA_API_KEY=
# AISSTREAM_API_KEY=
# OIL_INTEL_INTERNAL_KEY=
