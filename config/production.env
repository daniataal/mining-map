# Production feature flags and non-secret defaults.
# Deploy merges this file with GitHub Secrets via scripts/render_backend_env.sh → backend.env
# Edit here to turn platform capabilities on/off; add API keys once in GitHub Secrets.

# --- Honesty / prod defaults ---
OIL_LIVE_DISABLE_DEMO_SEED=1
OIL_INTEL_SEED_ON_STARTUP=false
MARITIME_GULF_DEMO_SEED=0
MARITIME_COASTAL_DEMO_SEED=0
DISABLE_POLLINATIONS_FALLBACK=1

# --- Search (requires docker compose --profile search) ---
ELASTICSEARCH_URL=http://elasticsearch:9200
SEARCH_INDEXER_INTERVAL_SECONDS=300

# --- API user agents (fair access policies) ---
SEC_EDGAR_USER_AGENT=MeridianMiningMap/1.0 (deploy)
GLEIF_USER_AGENT=MeridianMiningMap/1.0 (deploy)
WIKIDATA_USER_AGENT=MeridianMiningMap/1.0 (deploy)
TED_USER_AGENT=MeridianMiningMap/1.0 (deploy)
OPENSANCTIONS_USER_AGENT=Meridian/1.0 (deploy)
GOLDBOD_USER_AGENT=MeridianMiningMap/1.0 (deploy)

# --- Sync master switches (workers skip gracefully when keys or data dirs are missing) ---
COMTRADE_SYNC_ENABLED=true
CENSUS_TRADE_SYNC_ENABLED=true
USITC_TRADE_SYNC_ENABLED=true
EUROSTAT_SYNC_ENABLED=true
EIA_HISTORIC_SYNC_ENABLED=true
EIA_HISTORIC_AUTO_INGEST=true
UK_TRADE_MANIFEST_SYNC_ENABLED=true
BRAZIL_TRADE_MANIFEST_SYNC_ENABLED=true
GOV_PROCUREMENT_SYNC_ENABLED=true
TED_PROCUREMENT_SYNC_ENABLED=true
OIL_GRAPH_SYNC_ENABLED=true
PROBE_SYNC_ENABLED=true
PETROLEUM_OSM_SYNC_ENABLED=true
COMMODITY_COMTRADE_SYNC_ENABLED=true
JODI_SYNC_ENABLED=true
BARENTSWATCH_AIS_SYNC_ENABLED=true

# --- Go graph-sync cold steps (Python skips each step when matching flag is true) ---
OIL_GRAPH_SYNC_GO_TERMINAL_OPERATORS=true
OIL_GRAPH_SYNC_GO_LICENSES=true
OIL_GRAPH_SYNC_GO_TRADE_FLOWS=true
OIL_GRAPH_SYNC_GO_PORT_CALLS=true
OIL_GRAPH_SYNC_GO_TED=true
OIL_GRAPH_SYNC_GO_GOV_AWARDS=true
OIL_GRAPH_SYNC_GO_EUROSTAT_TRADE=true
OIL_GRAPH_SYNC_GO_PORT_CALL_MCR=true
# Enable after petroleum_osm cache exists (first Python graph-sync or manual materialize)
OIL_GRAPH_SYNC_GO_PETROLEUM_OSM_STORAGE=false
OIL_GRAPH_SYNC_GO_BUNKER_FUEL_SUPPLIERS=true

# --- Maritime / oil-live ---
OIL_INTEL_ENABLE_AIS=true
MARITIME_SSL_AUTO_FALLBACK=1
MARITIME_WORKER_WATCH_MODE=all_regions

# --- ShipVault registry backfill (auth secrets overlay from GitHub) ---
SHIPVAULT_BACKFILL_ENABLED=true
SHIPVAULT_BACKFILL_LIMIT=25
SHIPVAULT_BACKFILL_INTERVAL_HOURS=24
SHIPVAULT_CACHE_TTL_DAYS=7

# --- VM data paths (compose volume mounts under /opt/mining-map/data) ---
EIA_DOWNLOADS_DIR=/data/eia_downloads
UK_MANIFEST_CSV_DIR=/data/uk_trade_manifests
BRAZIL_MANIFEST_CSV_DIR=/data/brazil_trade_manifests
GEM_TRACKER_XLSX_PATH=/data/meridian/gem/Global-Oil-and-Gas-Extraction-Tracker-March-2026.xlsx
GEM_GOIT_PIPELINES_XLSX_PATH=/data/meridian/gem/GEM-GOIT-Oil-NGL-Pipelines-2025-03.xlsx
GEM_GOIT_ROUTES_DIR=/data/gem/goit-pipeline-routes/data/individual-routes/liquid-pipelines
GEM_TRACKER_AUTO_INGEST=true
GEM_GOIT_PIPELINES_AUTO_INGEST=true

# --- Overpass / storage (prod: skip live Overpass on startup; use DB + seeds) ---
STORAGE_SKIP_LIVE_OVERPASS=true
