# MadSan V2 — daily Postgres backup (cron example)
#
# Install on prod VM (standalone checkout at /opt/madsan):
#   crontab -e
#   # paste the cron block below
#
# Monorepo (pre-split): adjust REPO_ROOT to /opt/mining-map and script path to ./madsan/scripts/backup_db.sh
#
# Prerequisites:
#   - docker + docker compose available to the cron user
#   - madsan-db service running (compose stack up)
#   - repo checkout at REPO_ROOT; backups land in REPO_ROOT/backups/
#
# Verify manually first:
#   cd /opt/madsan && ./scripts/backup_db.sh
#   ls -lh backups/madsan_v2_pre_*.dump
#
# Optional: prune old dumps after N days (example — adjust retention):
#   find /opt/madsan/backups -name 'madsan_v2_pre_*.dump' -mtime +14 -delete

SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# Daily 02:30 local — timestamped dump via backup_db.sh
30 2 * * * cd /opt/madsan && ./scripts/backup_db.sh >> backups/backup_cron.log 2>&1
