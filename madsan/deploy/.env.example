# Copy to madsan/deploy/.env and adjust for your machine.
MADSAN_DB_PASSWORD=password
MADSAN_JWT_SECRET=change-me-in-production

# Browser → API (host ports when not using Caddy proxy)
NEXT_PUBLIC_API_URL=http://localhost:8088

# Legacy mining-db — hybrid dev (API/worker on host): 127.0.0.1:5434
# Full Docker stack overrides via docker-compose.yml → host.docker.internal:5434
LEGACY_DATABASE_URL=postgresql://postgres:password@127.0.0.1:5434/mining_db?sslmode=disable

# AIS sync from legacy oil_ais_positions
MADSAN_AIS_SYNC=true
MADSAN_AIS_SYNC_SEC=30

# Go legacy import (Python fallback off by default)
MADSAN_LEGACY_PYTHON=false

# Optional — EIA open-data daily crude spot (WTI/Brent) for /api/core/ticker
# Free key: https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# Optional — OpenSanctions API key for deal sanctions screening (better rate limits)
# https://www.opensanctions.org/docs/api/
OPENSANCTIONS_API_KEY=

# Optional — AISStream live AIS (not wired yet; legacy oil_ais_positions sync is default)
# AISSTREAM_API_KEY=
