# Canonical MadSan environment — copy to madsan/deploy/.env (no parent repo .env required).
# cp madsan/deploy/.env.example madsan/deploy/.env
#
# Deprecated: scripts/sync_env_from_root.sh (monorepo one-way migration only).

# --- Required ---
DATABASE_URL=postgresql://postgres:password@127.0.0.1:5433/madsan_db?sslmode=disable
MADSAN_DB_PASSWORD=password
# Prod arm64 VM: docker-compose.prod.yml defaults to imresamu/postgis (official postgis is amd64-only).
# Dev on Apple Silicon / amd64 laptop: leave unset or use postgis/postgis:16-3.4.
# MADSAN_DB_IMAGE=imresamu/postgis:16-3.6.1-bookworm
MADSAN_JWT_SECRET=change-me-in-production
# Cookie auth: Secure=false + SameSite=Lax in dev (default). Set true behind HTTPS in prod.
# MADSAN_COOKIE_SECURE=true
# MADSAN_COOKIE_DOMAIN=

# Browser → API. Leave unset in prod (Caddy same-origin /api + /tiles). Dev: http://localhost:8088
# NEXT_PUBLIC_API_URL=http://localhost:8088

# Legacy mining-db — hybrid dev only (go run ./cmd/api on host). Docker stack ignores this
# and uses host.docker.internal:5434 (see MADSAN_DOCKER_LEGACY_DATABASE_URL in compose).
LEGACY_DATABASE_URL=postgresql://postgres:password@127.0.0.1:5434/mining_db?sslmode=disable
# Optional override when legacy DB password/host differs inside Docker:
# MADSAN_DOCKER_LEGACY_DATABASE_URL=postgresql://postgres:password@host.docker.internal:5434/mining_db?sslmode=disable

# Direct AISStream ingest (Phase E — preferred over legacy 2-hop when key is set)
# Free key: https://aisstream.io/
# Compose: docker compose --profile ais up -d madsan-ais-ingest
# Hybrid dev: go run ./cmd/ais-ingest (separate from API on :8088)
AISSTREAM_API_KEY=
# When AISSTREAM_API_KEY is set, legacy oil_ais_positions sync is disabled by default.
# MADSAN_AIS_DIRECT=true
# MADSAN_AIS_RETAIN_DAYS=30
# MADSAN_AIS_GEOFENCE_RADIUS_M=1200
# Min seconds between ais_positions history rows per MMSI (default 90).
# Does NOT throttle vessels.lat/lon/last_seen_at upserts or vessel_delta NOTIFY.
# MADSAN_AIS_POSITION_MIN_SEC=90
# Prod overlay defaults (docker-compose.prod.yml): MADSAN_AIS_INGEST_MEM_LIMIT=512m, CPUS=0.5
# MADSAN_AIS_INGEST_MEM_LIMIT=512m
# MADSAN_AIS_INGEST_CPUS=0.5
# MARITIME_SSL_AUTO_FALLBACK=1

# Legacy 2-hop AIS sync (mining_db oil_ais_positions → madsan_db.vessels)
# Defaults to false when AISSTREAM_API_KEY is set; true otherwise.
# Set MADSAN_AIS_SYNC=true only for transitional dev without ais-ingest worker.
# MADSAN_AIS_SYNC=false
MADSAN_AIS_SYNC_SEC=30
# First SyncOnce watermark: import legacy oil_ais_positions back this far (default 7d).
MADSAN_AIS_SYNC_LOOKBACK_HOURS=168

# Go legacy import (Python fallback off by default)
MADSAN_LEGACY_PYTHON=false

# Raw ingestion dir (watch_folder, bunker_seed). Leave unset — auto-detects madsan/raw via go.mod.
# Self-contained under madsan/raw; repo-relative values normalize regardless of cwd.
# Full Docker stack sets MADSAN_RAW_DIR=/raw in compose.

# GEM xlsx trackers — place files in madsan/data/gem/ (see madsan/data/gem/README.md).

# Optional — EIA open-data daily crude spot (WTI/Brent) for /api/core/ticker
# Free key: https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# Optional — OpenSanctions API key for deal sanctions screening (better rate limits)
# https://www.opensanctions.org/docs/api/
OPENSANCTIONS_API_KEY=

# Optional — AI DD copilot on /deals (Groq preferred, OpenRouter fallback)
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Optional — document upload storage directory (default: madsan/data/documents)
# MADSAN_DOCUMENTS_DIR=

# ShipVault vessel registry enrichment (owner/operator batch + scheduler job)
# Free Firebase registration at https://www.shipvault.com — paste refresh token from DevTools.
# Auto-enabled in Docker when SHIPVAULT_BEARER_TOKEN is set (compose default: true).
MADSAN_SHIPVAULT_ENABLED=true
# SHIPVAULT_BEARER_TOKEN=
# SHIPVAULT_REFRESH_TOKEN=
# SHIPVAULT_SESSION_JSON=
# SHIPVAULT_EMAIL=
# SHIPVAULT_PASSWORD=
# SHIPVAULT_FIREBASE_API_KEY=
# SHIPVAULT_BASE_URL=https://shipvaultapi-gjb8c.ondigitalocean.app
# SHIPVAULT_APP_ORIGIN_URL=https://app.shipvault.io
# SHIPVAULT_CACHE_TTL_DAYS=120
# MADSAN_VESSEL_ENRICHMENT_BATCH=50
# MADSAN_VESSEL_ENRICHMENT_STALE_DAYS=120
# MADSAN_VESSEL_ENRICHMENT_RATE_MS=500
