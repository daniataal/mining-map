# Copy to .env and adjust. docker compose substitutes these values.

# AISStream (maritime-worker) — without a key the worker still runs but snapshots stay sparse.
AISSTREAM_API_KEY=

# Persian Gulf synthetic demo: default 1 in docker-compose so local maps show Hormuz demo dots
# when AISStream returns no Gulf positions. Set 0 to disable automatic merge (UI toggle can still opt in).
MARITIME_GULF_DEMO_SEED=1

# Optional: custom GeoJSON seed instead of built-in synthetic rows
# MARITIME_GULF_SEED_FILE=

GROQ_API_KEY=
OPENROUTER_API_KEY=
SECRET_KEY=

# Frontend (docker frontend service) — leave empty to use same-host API in the browser
# VITE_API_BASE=
