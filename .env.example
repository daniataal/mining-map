# Copy to .env and adjust. docker compose substitutes these values.
# Do not commit real API keys or secrets.

# AISStream (maritime-worker) — without a key the worker still runs but snapshots stay sparse.
AISSTREAM_API_KEY=

# Persian Gulf synthetic demo: default 1 in docker-compose so local maps show Hormuz demo dots
# when AISStream returns no Gulf positions. Set 0 to disable automatic merge (UI toggle can still opt in).
MARITIME_GULF_DEMO_SEED=1

# Optional: custom GeoJSON seed instead of built-in synthetic rows
# MARITIME_GULF_SEED_FILE=

# AI providers for due-diligence analysis (/api/ai/analyze). Set at least one key in production.
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Optional AI runtime tuning (seconds where applicable).
# AI_HTTP_TIMEOUT_SECONDS=18
# AI_HTTP_MAX_RETRIES=1
# AI_ANALYSIS_DEADLINE_SECONDS=45
# AI_ENRICHMENT_DEADLINE_SECONDS=20

# Pollinations free-text fallback (off when DISABLE_POLLINATIONS_FALLBACK=1).
# GitHub deploy workflow sets DISABLE_POLLINATIONS_FALLBACK=1 by default — expected when keys are missing.
# POLLINATIONS_HTTP_TIMEOUT_SECONDS=12
# POLLINATIONS_HTTP_MAX_RETRIES=0
# DISABLE_POLLINATIONS_FALLBACK=1
#
# Health (no secrets): curl -s http://localhost:8000/api/health | jq .ai_providers
#
# Safe verification inside the backend container (SET/MISSING only):
# docker compose exec backend python -c "import os; keys=('GROQ_API_KEY','OPENROUTER_API_KEY','DISABLE_POLLINATIONS_FALLBACK'); [print(f'{k}={\"SET\" if os.getenv(k) else \"MISSING\"}') for k in keys]"
#
# Ubuntu server after GitHub deploy — add repo secrets GROQ_API_KEY and/or OPENROUTER_API_KEY,
# redeploy, or on the host create /opt/mining-map/.env with keys and run:
#   cd /opt/mining-map && export $(grep -v '^#' .env | xargs) && sudo -E docker compose up -d backend
SECRET_KEY=

# Frontend (docker frontend service) — leave empty to use same-host API in the browser
# VITE_API_BASE=
