# Local docker compose: copy this file to repo-root `.env` OR put runtime secrets in `backend.env`
# (same directory as docker-compose.yml). Compose loads both (optional) via env_file; do not rely
# on empty `AISSTREAM_API_KEY=${AISSTREAM_API_KEY}` passthrough — that overrides backend.env.
#
# Production deploy: .github/workflows/docker-image.yml maps GitHub secret names → runtime env
# and writes /opt/mining-map/backend.env on the VM (/opt/mining-map). Do not commit real API keys.
#
# GitHub secret name          →  Container / runtime env (this file uses runtime names)
# ---------------------------------------------------------------------------
# GROQ_AI_API_KEY             →  GROQ_API_KEY  (backend also accepts GROQ_AI_API_KEY directly)
# OPENROUTER_AI_API_KEY       →  OPENROUTER_API_KEY  (alias: OPENROUTER_AI_API_KEY)
# Legacy secrets GROQ_API_KEY / OPENROUTER_API_KEY still work if set in GitHub instead.
# MAPBOX_ACCESS_TOKEN         →  MAPBOX_ACCESS_TOKEN  (alias: MAPBOX_TOKEN in workflow)
# AISSTREAM_API_KEY           →  AISSTREAM_API_KEY
# ADMIN_TOKEN                 →  ADMIN_TOKEN
# COMTRADE_API_KEY            →  COMTRADE_API_KEY
# COMTRADE_API_KEY_SECONDARY  →  COMTRADE_API_KEY_SECONDARY  (optional failover)
# EIA_API_KEY                 →  EIA_API_KEY
# CENSUS_API_KEY              →  CENSUS_API_KEY  (graph-sync macro trade; required in prod)
# USITC_DATAWEB_API_KEY       →  USITC_DATAWEB_API_KEY  (graph-sync USITC DataWeb; required in prod)
# KZ_EGOV_API_KEY             →  KZ_EGOV_API_KEY
# OPENSANCTIONS_API_KEY       →  OPENSANCTIONS_API_KEY
# COURTLISTENER_API_KEY       →  COURTLISTENER_API_KEY
# SYNC_ALERT_WEBHOOK_URL      →  SYNC_ALERT_WEBHOOK_URL  (optional drift alerts)
# OIL_INTEL_INTERNAL_KEY      →  OIL_INTEL_INTERNAL_KEY  (backend ↔ oil-live-intel; required in prod)
# SECRET_KEY                  →  SECRET_KEY  (JWT/session signing; required in prod)
# DOCKER_USERNAME/PASSWORD    →  (CI only — image registry login)
# REMOTE_HOST/USER/SSH_KEY    →  (CI only — deploy SSH)
# licenses_export.csv artifact → /opt/mining-map/data/licenses_export.csv (optional CSV on deploy)
# GOOGLE_MAPS_ANDROID_API_KEY →  (meridian-mobile APK workflow only)
# (optional) GOOGLE_CSE_API_KEY + GOOGLE_CSE_CX or GOOGLE_CSE_ID → contact agent web discovery
# (optional) SERPAPI_API_KEY → contact agent web discovery (alternate to Google CSE)

# AISStream (maritime-worker + backend read path) — required for live vessel snapshots.
# Local: set here in .env OR in backend.env (either works after `docker compose up`).
# VM: key lives in /opt/mining-map/backend.env; recreate worker after changes:
#   sudo docker compose up -d --force-recreate maritime-worker backend
AISSTREAM_API_KEY=

# TLS for wss://stream.aisstream.io (default verify on). If the worker logs
# "certificate has expired" for stream.aisstream.io, the upstream cert needs renewal;
# MARITIME_SSL_VERIFY=0 is a dev-only bypass until AISStream renews (not for production).
# Does NOT fix empty Live Data terminals — those need oil-live-intel + graph-sync (see docs/LIVE_DATA.md).
# MARITIME_SSL_VERIFY=1
# MARITIME_SSL_AUTO_FALLBACK=1
# When AISStream TLS cert expires upstream, workers retry without verify once (auto-fallback, default on).
# OIL_INTEL_AIS_INSECURE_TLS=true  # Go oil-live-intel-worker: force skip verify (dev only; prefer auto-fallback)

# Optional future AIS providers (not used unless MARITIME_AIS_PROVIDER is changed in code):
# MARITIME_AIS_PROVIDER=aisstream
# MYSHIPTRACKING_API_KEY=   # REST trial/paid — https://api.myshiptracking.com/
# MARINESIA_API_KEY=        # REST free tier ~1 req/hr — https://marinesia.com/

# BarentsWatch government AIS (Norway EEZ) — graph-sync step barentswatch_ais (MAD-61)
# Register client: https://developer.barentswatch.no/docs/AIS/live-ais-api/
# BARENTSWATCH_AIS_SYNC_ENABLED=true
# BARENTSWATCH_CLIENT_ID=
# BARENTSWATCH_CLIENT_SECRET=
# BARENTSWATCH_AIS_MAX_VESSELS=500

# Maritime demo seeds: production and customer API always use 0 (honest AIS/snapshot only).
MARITIME_GULF_DEMO_SEED=0
MARITIME_COASTAL_DEMO_SEED=0
# MARITIME_ALLOW_DEMO_SEED=0  # dev-only master switch; never set in prod/Caddy. Required with *_DEMO_SEED=1 for local synthetic demos.

# Optional: custom GeoJSON seed instead of built-in synthetic rows (dev-only, with MARITIME_ALLOW_DEMO_SEED=1)
# MARITIME_GULF_SEED_FILE=

# Worker tuning (defaults shown in backend/services/maritime_intel.py):
# MARITIME_WORKER_WATCH_MODE=all_regions   # all_regions | global | rotating
# MARITIME_COASTAL_SUPPLEMENT_MAX_VESSELS=2500  # per-box supplemental capture for Gulf of Guinea / Horn / Red Sea / East Africa
# MARITIME_MEMORY_CACHE_MAX_VESSELS=10000
# MARITIME_WORKER_MAX_VESSELS=15000
#
# Sparse Gulf/Africa coverage: widen worker watch (all_regions) and supplements — not synthetic demo fill.

# Marketplace license export (backend/main.py — fail closed when unset or demo-key)
# MARKETPLACE_API_URL=http://host.docker.internal:3001/api/v1/ingest
# MARKETPLACE_API_KEY=              # production: set a real key; leave unset to skip export

# AI providers for due-diligence analysis (/api/ai/analyze). Set at least one key in production.
# Local: set GROQ_API_KEY / OPENROUTER_API_KEY here. GitHub: use secrets GROQ_AI_API_KEY / OPENROUTER_AI_API_KEY.
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Optional: Programmable Search (Google Custom Search JSON API) or SerpAPI for the dossier
# "Find contacts" agent when cadastre fields omit phone/email/website. Uses bounded HTTP fetch +
# mailto/tel/text extraction only (no LLM). Prefer official APIs over scraping search UIs.
# Create a Programmable Search Engine at https://programmablesearchengine.google.com/ (search the entire web).
# GOOGLE_CSE_API_KEY=
# GOOGLE_CSE_CX=   # Search engine ID (same as "cx" query param; alias: GOOGLE_CSE_ID)
# SERPAPI_API_KEY=

# Optional AI runtime tuning (seconds where applicable).
# AI_HTTP_TIMEOUT_SECONDS=18
# AI_HTTP_MAX_RETRIES=1
# AI_ANALYSIS_DEADLINE_SECONDS=45
# AI_ENRICHMENT_DEADLINE_SECONDS=20

# Pollinations free-text fallback (off when DISABLE_POLLINATIONS_FALLBACK=1).
# GitHub deploy workflow sets DISABLE_POLLINATIONS_FALLBACK=1 by default — expected when keys are missing.
# POLLINATIONS_HTTP_TIMEOUT_SECONDS=12
# POLLINATIONS_HTTP_MAX_RETRIES=0
# DISABLE_POLLINATIONS_FALLBACK=1
#
# Health (no secrets): curl -s http://localhost:8000/api/health | jq .ai_providers
#
# Safe verification inside the backend container (SET/MISSING only):
# docker compose exec backend python -c "import os; keys=('GROQ_API_KEY','OPENROUTER_API_KEY','DISABLE_POLLINATIONS_FALLBACK'); [print(f'{k}={\"SET\" if os.getenv(k) else \"MISSING\"}') for k in keys]"
#
# After GitHub deploy, keys live in /opt/mining-map/backend.env (runtime names GROQ_API_KEY,
# OPENROUTER_API_KEY). Re-run the docker-image workflow after adding GitHub secrets
# GROQ_AI_API_KEY / OPENROUTER_AI_API_KEY. Do not use bare `environment: - GROQ_API_KEY`
# passthrough on the server — it can override backend.env with an empty host value.
# On the VM you can also set keys in backend.env and run: sudo docker compose up -d --force-recreate backend
SECRET_KEY=

# Route Intelligence microservice (docker compose starts route-service on internal :8001).
# Backend proxies when ROUTE_SERVICE_URL is set; browser uses main API unless overridden.
# ROUTE_SERVICE_URL=http://route-service:8001
# ROUTE_SERVICE_MEM_LIMIT=3g
# ROUTE_PLAN_DEADLINE_SEC=120
# OSRM_GEOMETRY_CACHE_MAX=8192
#
# Routing geometry (free/open sources; see docs/ROUTING_ENGINES.md)
# OSRM_BASE_URL=https://router.project-osrm.org
# Optional self-hosted OSRM (regional driving graph): set URL to http://osrm:5000 after enabling compose profile
# SEAROUTE_ENABLED=1
# OSRM_TIMEOUT_SEC=8
# SEAROUTE_TIMEOUT_SEC=15
# RAIL_OVERPASS_URL=https://overpass-api.de/api/interpreter

# OSM-only petroleum map mode — hide Mapbox/oilmap layers; use OSM pipelines/refineries.
# PETROLEUM_DISABLE_MAPBOX=1
# VITE_PETROLEUM_DISABLE_MAPBOX=1   # frontend mirror (mining-viz build-time)

# ArcGIS probe worker (KZ hub + PH MGB token probe → open_data_probe_results)
# PROBE_SYNC_ENABLED=true
# PROBE_SYNC_INTERVAL_SECONDS=604800

# Mapbox — backend petroleum layers (/api/petroleum/*) and optional license geocoding.
# GitHub secret MAPBOX_ACCESS_TOKEN → runtime MAPBOX_ACCESS_TOKEN (MAPBOX_TOKEN alias in workflow).
# Local: paste your public token (pk.*) below, then: docker compose up -d --build backend
MAPBOX_ACCESS_TOKEN=
# Optional alias (same value as MAPBOX_ACCESS_TOKEN); backend checks both.
# OILMAP_MAPBOX_TOKEN=
# Optional separate token for admin geocoding; defaults to Nominatim when unset.
# MAPBOX_GEOCODING_TOKEN=

# Kazakhstan solid-minerals register (data.egov.kz) — free API key from https://data.egov.kz
# Enables POST /api/admin/kazakhstan-mining/sync and unattended egov ingest.
# KZ_EGOV_API_KEY=
# KZ_EGOV_API_BASE=https://data.egov.kz/api/v4
# KZ_EGOV_SYNC_INTERVAL_SECONDS=86400
# kazakhstan-mining-worker skips gracefully when key unset

# Downstream fuel / petroleum products marketing licensees (curated seed JSON).
# No API keys — POST /api/admin/oil-products-licenses/sync loads data/oil_products_licenses_seed.json
# and runs automatically on startup alongside OPEC Gulf reference sync.

# Storage / tank farms layer (Oil & Gas view) — GET /api/storage/terminals
# 1. OpenStreetMap via Overpass (11 world tiles; tries kumi.systems then overpass-api.de)
#    Tags: industrial=petroleum_terminal|tank_farm|fuel, man_made=storage_tank with petroleum substance, etc.
# 2. petroleum_osm_features DB snapshot (when globally complete, or when live Overpass fails)
# 3. Offline bulk seed — backend/data/oil_terminals_seed_bulk.json (297+ terminals for Docker/CI)
# 4. Curated reference seed — data/storage_terminals_seed.json (major global hubs, sourceKind=curated_reference)
# Optional Overpass overrides (same as petroleum OSM sync worker):
# STORAGE_OVERPASS_URL=https://overpass.kumi.systems/api/interpreter
# OVERPASS_URL=https://overpass.kumi.systems/api/interpreter
# STORAGE_OVERPASS_TIMEOUT_SECONDS=120
# STORAGE_OVERPASS_QUERY_TIMEOUT_SECONDS=90
# STORAGE_OVERPASS_RETRY_ATTEMPTS=3
# STORAGE_OVERPASS_RETRY_DELAY_SECONDS=4
# STORAGE_OVERPASS_TILE_WORKERS=3
# STORAGE_SKIP_LIVE_OVERPASS=true   # Docker/CI default — use DB + bulk seed without blocking on Overpass
# Failed force_refresh does NOT overwrite the in-memory cache — graph-sync falls back to cache/DB/bulk seed.
# Stale regional-only DB snapshot? GET /api/storage/terminals?force_refresh=true

# License open-data sync drift alerts when records_written drops vs previous run (percent).
# SYNC_DRIFT_ALERT_PCT=20

# SEC EDGAR User-Agent (required by SEC fair-access policy for company_tickers.json).
# SEC_EDGAR_USER_AGENT=MeridianMiningMap/1.0 (contact: you@example.com)

# UN Comtrade API (free tier ~500 req/day) — https://comtradeplus.un.org/
# Enables POST /api/admin/comtrade/sync and comtrade-sync-worker daily HS27 refresh.
# COMTRADE_API_KEY=          # primary subscription key (GitHub secret COMTRADE_API_KEY on deploy)
# COMTRADE_API_KEY_SECONDARY=  # optional failover on HTTP 429/403 from primary
# COMTRADE_SYNC_ENABLED=true

# U.S. EIA open data (petroleum enrichment) — https://www.eia.gov/opendata/
# Used by backend/services/eia_imports.py:
#   sync_eia_crude_imports         → oil_trade_flows (data_source='eia', HS 2709)
#   sync_eia_refinery_throughput   → oil_refinery_throughput (PADD utilisation)
# Both functions skip cleanly when EIA_API_KEY is unset (logged warning only).
EIA_API_KEY=               # GitHub secret EIA_API_KEY on deploy

# EIA Petroleum Supply Monthly — user-downloaded impa*.xls/xlsx (company-level U.S. imports).
# Not scraped from eia.gov. Compose mounts ./data/eia_downloads → /data/eia_downloads
# EIA_DOWNLOADS_DIR=/data/eia_downloads
# EIA_HISTORIC_AUTO_INGEST=true          # graph-sync step + worker (default on)
# EIA_HISTORIC_STARTUP_INGEST=false      # set true to parse xls on backend boot (prefer worker only)
# EIA_HISTORIC_FORCE_REINGEST=false      # set true to re-parse all impa files even if unchanged
# EIA_HISTORIC_SYNC_ENABLED=true         # eia-historic-sync-worker (scheduler; reads DB if files unchanged)
# EIA_HISTORIC_SYNC_INTERVAL_SECONDS=21600
# GEM Global Oil and Gas Extraction Tracker (March 2026 xlsx at repo root)
# GEM_TRACKER_XLSX_PATH=/workspace/repo/Global-Oil-and-Gas-Extraction-Tracker-March-2026.xlsx
# GEM_TRACKER_AUTO_INGEST=true          # graph-sync step (default on when workbook present)

# Production data depth (VM checklist)
# OIL_LIVE_DISABLE_DEMO_SEED=1
# OIL_GRAPH_SYNC_INTERVAL_SECONDS=43200
# UK_MANIFEST_CSV_DIR=/data/uk_trade_manifests
# UK_TRADE_MANIFEST_SYNC_ENABLED=true
# COMMODITY_COMTRADE_SYNC_ENABLED=true
# COMMODITY_COMTRADE_REPORTERS=834,288,404,710,894,180,604,170

# 23GB+ VM: docker compose -f docker-compose.prod.yml -f docker-compose.prod.large-vm.yml up -d

# DD legal intel (backend/services/legal_intel.py — all optional)
# Without keys: dossier shows labelled stub_fixture litigation placeholders.
# COURTLISTENER_API_KEY=     # live U.S. court search — GitHub secret on deploy
# OPENSANCTIONS_API_KEY=     # higher-rate-limit sanctions/PEP key — public API works without
# LEGAL_INTEL_DISABLED=1     # force stubs even when keys are present

# OpenSanctions screening for oil_companies (backend/services/opensanctions_screening.py)
# Public API works without a key (≈1 req/s); set OPENSANCTIONS_API_KEY for higher rate limits.
# OPENSANCTIONS_API_KEY=
# OPENSANCTIONS_BATCH_LIMIT=50         # rows per graph-sync run
# OPENSANCTIONS_USER_AGENT=Meridian/1.0 (ops@meridian.example)

# GLEIF LEI batch enrichment (backend/services/gleif_batch.py)
# No API key required (GLEIF public API).
# GLEIF_BATCH_LIMIT=100                # rows per graph-sync run
# GLEIF_BATCH_SLEEP=0.4                # seconds between requests
# GLEIF_BATCH_MIN_SCORE=0.0

# Wikidata company enrichment (backend/services/wikidata_company_enrichment.py)
# Public MediaWiki API; identify yourself in User-Agent per Wikimedia policy.
# WIKIDATA_BATCH_LIMIT=50              # rows per graph-sync run
# WIKIDATA_USER_AGENT=Meridian/1.0 (ops@meridian.example)

# Ghana Gold Board (GoldBod) license verification — backend/services/goldbod.py
# No public REST API documented; default matches official License Registry HTML.
# GET /entities/{id}/goldbod-license  ·  GET /api/ghana/goldbod/search?q=...
# GOLDBOD_API_BASE_URL=      # optional partner / SSMOS / GoldBod Trace API root
# GOLDBOD_API_KEY=           # bearer key when base URL is set
# GOLDBOD_REGISTRY_URL=https://goldbod.net/license-registry/index.html
# GOLDBOD_CACHE_TTL_SECONDS=86400
# GOLDBOD_REGISTRY_DISABLED=1   # manual links + checklist only
# GOLDBOD_USER_AGENT=MeridianMiningMap/1.0 (contact: you@example.com)

# Frontend: bundled licenses.json fallback only on localhost unless explicitly enabled
# VITE_ALLOW_BUNDLED_LICENSE_FALLBACK=0
# COMTRADE_SYNC_YEAR=2023
# COMTRADE_SYNC_SLEEP_SECONDS=1.2
# COMTRADE_SYNC_INTERVAL_SECONDS=86400

# GLEIF LEI lookup User-Agent (optional; GET /api/companies/{name}/lei)
# GLEIF_USER_AGENT=MeridianMiningMap/1.0 (contact: you@example.com)

# OSM petroleum persistence worker (Overpass → petroleum_osm_features)
# PETROLEUM_OSM_SYNC_ENABLED=true
# PETROLEUM_OSM_SYNC_INTERVAL_SECONDS=86400
# PETROLEUM_OSM_TILE_SLEEP_SECONDS=2.0

# Sweden SGU OGC mineral permits (POST /api/admin/sweden-mining/sync)
# SGU_MINING_SYNC_ENABLED=true
# SGU_SYNC_MAX_PER_COLLECTION=1500
# SGU_SYNC_INTERVAL_SECONDS=604800
# sweden-mining-worker in docker-compose (weekly default)

# Poland PGI MIDAS mining areas (POST /api/admin/poland-mining/sync)
# PGI_MINING_SYNC_ENABLED=true
# PGI_SYNC_MAX_PER_LAYER=2000

# EU TED procurement — free Search API, no key (POST /api/admin/eu-procurement/sync)
# TED_PROCUREMENT_SYNC_ENABLED=true
# TED_PROCUREMENT_SYNC_INTERVAL_SECONDS=604800
# TED_USER_AGENT=MeridianMiningMap/1.0 (contact: you@example.com)

# U.S. USAspending federal contractors (gov-procurement-sync-worker in docker-compose)
# GOV_PROCUREMENT_SYNC_ENABLED=true
# GOV_PROCUREMENT_SYNC_INTERVAL_SECONDS=604800
# GOV_PROCUREMENT_SYNC_BACKOFF_SECONDS=3600
# GOV_PROCUREMENT_SYNC_MAX_PAGES_PER_PROFILE=3
# GOV_PROCUREMENT_SYNC_SLEEP_SECONDS=0.25
# GOV_PROCUREMENT_DISABLED=0
# Optional one-shot sync on API startup (worker is preferred):
# GOV_PROCUREMENT_SYNC_ON_STARTUP=true

# License sync drift → sync_alert_events + optional webhook POST
# SYNC_ALERT_WEBHOOK_URL=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_FROM=
# SMTP_TO=admin@example.com,ops@example.com
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_USE_TLS=true

# Kazakhstan ArcGIS hub probe (data-health; optional sync when layer verified)
# KZ_ARCGIS_PROBE_TIMEOUT_SECONDS=12
# KZ_ARCGIS_HYDROCARBON_LAYER_URL=https://arcgis.gis-center.kz/server/rest/services/.../FeatureServer/0
# KZ_ARCGIS_SYNC_ENABLED=0
# KZ_ARCGIS_SYNC_MAX_RECORDS=1500

# Philippines MGB ControlMap probe (token-gated; data-health only)
# PH_MGB_ARCGIS_TOKEN=
# PH_MGB_ARCGIS_PROBE_TIMEOUT_SECONDS=15

# Public app URL for drift alert emails/webhooks (deep link to admin data-health)
# APP_PUBLIC_URL=https://your-meridian-host.example
# ADMIN_DATA_HEALTH_PATH=/admin?tab=data-health

# Per-source sync SLA thresholds (hours since last successful sync)
# SYNC_SLA_GREEN_HOURS=24
# SYNC_SLA_YELLOW_HOURS=72
# SYNC_SLA_RED_HOURS=168

# oil-live-intel (Go service, port 8095) — live tanker/terminal intelligence
# AISSTREAM_API_KEY=      # same key as maritime-worker; optional for demo (seed data works without)
# EIA_API_KEY=
# COMTRADE_API_KEY=
# OIL_INTEL_ENABLE_AIS=true   # worker + API; requires AISSTREAM_API_KEY
# Start AIS ingest explicitly:
# docker compose up -d maritime-worker oil-live-intel-worker
# OIL_INTEL_ENABLE_OSM_IMPORT=false
# OIL_INTEL_AIS_INSECURE_TLS=true   # dev only if AISStream TLS fails in Docker
# OIL_INTEL_INTERNAL_KEY=oil-intel-dev
# OIL_INTEL_API_URL=http://oil-live-intel:8095
# Meridian commercial graph (Python backend → mining_db)
# OIL_GRAPH_SYNC_ENABLED=true
# OIL_GRAPH_SYNC_ON_STARTUP=false
# OIL_GRAPH_STORAGE_IMPORT_CAP=15000
# OIL_GRAPH_SYNC_INTERVAL_SECONDS=86400
# Real data only: skip demo port-call / opportunity seeds (graph-sync + oil-live-intel startup seed).
# Default 1 — set 0 only for local UI demos (MT DEMO STAR, seed_port_calls corridor filler).
OIL_LIVE_DISABLE_DEMO_SEED=1
# Multi-source vessel map merge (oil_vessel_position_observations). Default off until mirror ingested.
# OIL_LIVE_MERGED_VESSEL_POSITIONS=1

# ShipVault vessel registry enrichment (oil-live-intel Go service).
# Enables the "Registry" tab in the vessel drawer showing owner, builder, name history, and value.
# When all three vars are set, Firebase REST auth auto-refreshes the token every 50 min.
# Token is NEVER logged — only stored in memory. Cache TTL default: 7 days in Postgres.
# SHIPVAULT_EMAIL=            # your ShipVault account email
# SHIPVAULT_PASSWORD=         # your ShipVault account password
# SHIPVAULT_FIREBASE_API_KEY= # ShipVault's Firebase Web API Key (public; find in their app JS bundle)
# SHIPVAULT_CACHE_TTL_DAYS=7  # how long to serve cached enrichment before re-fetching
# SHIPVAULT_BASE_URL=https://shipvaultapi-gjb8c.ondigitalocean.app  # ShipVault API base
# To find SHIPVAULT_FIREBASE_API_KEY: open ShipVault in browser → DevTools → Network → sign in →
#   look for identitytoolkit.googleapis.com request → URL param "key=" is the Firebase API key.

# Elasticsearch search index (oil-live-intel: powers /api/oil-live/search).
# Host dev defaults to http://localhost:9200; in compose the indexer + API use http://elasticsearch:9200.
ELASTICSEARCH_URL=http://localhost:9200
# How often the oil-live-search-indexer re-syncs Postgres → ES (default 300s).
# SEARCH_INDEXER_INTERVAL_SECONDS=300

# U.S. macro trade supplements (country-level, not company BOL)
# Free Census key: https://api.census.gov/data/key_signup.html
# CENSUS_API_KEY=            # GitHub secret CENSUS_API_KEY on deploy
# CENSUS_TRADE_SYNC_ENABLED=true
# CENSUS_TRADE_SYNC_YEAR=2024
# USITC DataWeb (free account at https://dataweb.usitc.gov/ → API tab → Bearer token)
# USITC_DATAWEB_API_KEY=     # GitHub secret USITC_DATAWEB_API_KEY on deploy
# USITC_TRADE_SYNC_ENABLED=true

# Eurostat COMEXT-style EU macro trade (no API key; public REST)
# EUROSTAT_SYNC_ENABLED=true
# EUROSTAT_DATASET=EXT_LT_INTRATRD

# JODI oil supply/demand snapshots (user-provided CSV export)
# JODI_SYNC_ENABLED=true
# JODI_CSV_PATH=/path/to/jodi_world.csv
# JODI_CSV_URL=

# Frontend (docker frontend service) — leave empty to use same-host API in the browser
# Log in via the app UI; JWT is stored in localStorage as mining_token (required for
# GET /api/licenses/annotations — 401 without a valid session is expected and uses local cache).
# Optional script/debug token — do NOT commit real JWTs:
# MINING_TOKEN=
# Vite dev proxy to oil-live-intel (host: localhost:8095; Docker frontend: oil-live-intel:8095)
# OIL_INTEL_PROXY_TARGET=http://localhost:8095
# VITE_ADMIN_API_TOKEN=   # optional: X-Admin-Token for Comtrade / data-health tabs in Admin Panel
# VITE_API_BASE=
# VITE_OIL_INTEL_BASE=    # empty = same origin via Caddy/Vite proxy to /api/oil-live
# MAD-42: optional Go license map clusters (zoom < 7); Python /licenses remains for points + CRUD
# Low-zoom license map clusters via Go (opt in: VITE_LICENSE_MAP_GO=1; default uses /licenses via Caddy)
# VITE_LICENSE_MAP_GO=0
# LICENSE_MAP_GO_ENABLED=0
# Direct browser → route-service (dev only; host must expose route-service port)
# VITE_ROUTE_SERVICE_URL=
